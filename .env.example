# ===========================================
# Sanctum Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------
# API Keys (REQUIRED)
# -----------------------------------------
# Get your API key from trymaple.ai after upgrading to Pro/Team/Max
# Sanctum is Maple-only for LLM inference
LLM_PROVIDER=maple
MAPLE_API_KEY=your-maple-api-key-here
# Optional Maple overrides (defaults shown)
# MAPLE_BASE_URL=http://maple-proxy:8080/v1
# MAPLE_MODEL=kimi-k2.5

# -----------------------------------------
# Email Configuration (REQUIRED for production)
# -----------------------------------------
# For development, leave MOCK_EMAIL=true or SMTP_HOST empty
# Magic links will be logged to console instead of sent
#
# For production, set MOCK_EMAIL=false and configure SMTP
# See docs/email-auth.md for detailed provider setup

MOCK_EMAIL=true
SMTP_PORT=587
# SMTP_TIMEOUT=10  # Connection timeout in seconds (default: 10)

# --- Choose ONE provider below and uncomment ---

# Gmail (requires App Password from myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=Sanctum <yourname@gmail.com>

# Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your-mailgun-smtp-password
# SMTP_FROM=Sanctum <noreply@mg.yourdomain.com>

# SendGrid (SMTP_USER is literally "apikey")
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key
# SMTP_FROM=Sanctum <noreply@yourdomain.com>

# Amazon SES (use your region, FROM must be verified)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_USER=your-ses-smtp-username
# SMTP_PASS=your-ses-smtp-password
# SMTP_FROM=Sanctum <noreply@yourdomain.com>

# Postmark (user and pass are both your Server API Token)
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_USER=your-server-api-token
# SMTP_PASS=your-server-api-token
# SMTP_FROM=Sanctum <noreply@yourdomain.com>

# Brevo (formerly Sendinblue)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_USER=your-brevo-login-email
# SMTP_PASS=your-smtp-key
# SMTP_FROM=Sanctum <noreply@yourdomain.com>

# -----------------------------------------
# Frontend URL (REQUIRED for production)
# -----------------------------------------
# Used for magic link URLs in emails
# Development default: http://localhost:5173
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------
# Optional: Security
# -----------------------------------------
# SECRET_KEY is auto-generated and persisted to /data/.secret_key
# Only set this if you need a specific key (e.g., for load balancing)
# SECRET_KEY=your-64-char-hex-key

# -----------------------------------------
# Optional: Embedding Model
# -----------------------------------------
# Embeddings run locally using sentence-transformers models.
# Default:
# EMBEDDING_MODEL=intfloat/multilingual-e5-base

# -----------------------------------------
# Optional: Development/Testing
# -----------------------------------------
# ⚠️  WARNING: NEVER enable in production - bypasses authentication!
# SIMULATE_USER_AUTH bypasses magic link verification
# SIMULATE_ADMIN_AUTH shows mock Nostr button (grants admin UI access)
# See docs/authentication.md for testing workflows
# SIMULATE_USER_AUTH=true
# SIMULATE_ADMIN_AUTH=true
